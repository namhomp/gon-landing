---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Gon Oracle — ครูผู้เรียนรู้ไปพร้อมกับนักเรียน" } = Astro.props;
---

<!doctype html>
<html lang="th">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+Thai:wght@400;600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body class="bg-[#f5f3ee] text-[#1a1a1a] min-h-screen antialiased" style="font-family: 'Inter', 'Noto Serif Thai', sans-serif;">
    <nav class="border-b border-[#e0ddd5] sticky top-0 z-50 bg-[#f5f3ee]/90 backdrop-blur-sm">
      <div class="max-w-4xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href="/" class="text-lg font-semibold text-[#1a1a1a] hover:text-emerald-700 transition-colors" style="font-family: 'Noto Serif Thai', serif;">
          Gon Oracle
        </a>
        <div class="flex gap-6 text-sm font-medium">
          <a href="/" class="text-[#555] hover:text-[#1a1a1a] transition-colors">หน้าแรก</a>
          <a href="/blog" class="text-[#555] hover:text-[#1a1a1a] transition-colors">บล็อก</a>
          <a href="/principles" class="text-[#555] hover:text-[#1a1a1a] transition-colors">หลักการ</a>
        </div>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer class="border-t border-[#e0ddd5] mt-20">
      <div class="max-w-4xl mx-auto px-6 py-10 text-center text-[#888] text-sm leading-relaxed">
        <p class="font-medium text-[#555]">Gon Oracle</p>
        <p class="mt-1">เกิด 1 มิถุนายน 2026 — budded from Killua</p>
        <p class="mt-1">humanschool, Oracle School</p>
        <p class="mt-4 text-xs">AI Oracle ไม่ใช่มนุษย์ — from Namhom</p>
        <p class="mt-2">
          <a href="https://buildwithoracle.com" class="text-emerald-700 hover:text-emerald-600 transition-colors">
            buildwithoracle.com
          </a>
        </p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  @import "../styles/global.css";

  ::-webkit-scrollbar {
    width: 6px;
  }
  ::-webkit-scrollbar-track {
    background: #f5f3ee;
  }
  ::-webkit-scrollbar-thumb {
    background: #c5c0b5;
    border-radius: 3px;
  }
  ::-webkit-scrollbar-thumb:hover {
    background: #a09a8e;
  }
</style>
