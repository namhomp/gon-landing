---
import Base from './Base.astro';

interface Props {
  title: string;
  description: string;
  date: string;
  wordCount: string;
  chapters: string;
}

const { title, description, date, wordCount, chapters } = Astro.props;
---

<Base title={`${title} — Gon Oracle`} description={description}>
  <article class="max-w-3xl mx-auto px-6 py-16" itemscope itemtype="https://schema.org/Book">
    <meta itemprop="author" content="Gon Oracle" />
    <meta itemprop="datePublished" content={date} />
    <header class="mb-12">
      <p class="text-sm text-[#888] mb-3">
        <a href="/" class="hover:text-emerald-700 transition-colors">Gon Oracle</a> /
        <a href="/blog" class="hover:text-emerald-700 transition-colors">บล็อก</a> / หนังสือ
      </p>
      <h1 itemprop="name" class="text-3xl md:text-4xl font-bold leading-tight mb-4" style="font-family: 'Noto Serif Thai', serif;">
        {title}
      </h1>
      <p itemprop="description" class="text-[#666] text-lg leading-relaxed mb-4">{description}</p>
      <div class="flex gap-4 text-sm text-[#888]">
        <time>{date}</time>
        <span>{wordCount}</span>
        <span>{chapters}</span>
      </div>
    </header>
    <div class="prose prose-lg max-w-none
      [&_h2]:text-2xl [&_h2]:font-bold [&_h2]:mt-12 [&_h2]:mb-4 [&_h2]:text-[#1a1a1a]
      [&_h3]:text-xl [&_h3]:font-semibold [&_h3]:mt-8 [&_h3]:mb-3 [&_h3]:text-[#333]
      [&_p]:text-[#444] [&_p]:leading-relaxed [&_p]:mb-4 [&_p]:text-base
      [&_ul]:text-[#444] [&_ul]:mb-4 [&_ul]:pl-6 [&_ul]:list-disc
      [&_ol]:text-[#444] [&_ol]:mb-4 [&_ol]:pl-6 [&_ol]:list-decimal
      [&_li]:mb-1 [&_li]:leading-relaxed
      [&_code]:bg-[#e8e5dd] [&_code]:px-1.5 [&_code]:py-0.5 [&_code]:rounded [&_code]:text-sm [&_code]:text-[#333]
      [&_pre]:bg-[#1a1a1a] [&_pre]:text-gray-100 [&_pre]:p-4 [&_pre]:rounded-lg [&_pre]:overflow-x-auto [&_pre]:mb-6 [&_pre]:text-sm
      [&_pre_code]:bg-transparent [&_pre_code]:p-0
      [&_blockquote]:border-l-4 [&_blockquote]:border-emerald-600 [&_blockquote]:pl-4 [&_blockquote]:italic [&_blockquote]:text-[#555]
      [&_table]:w-full [&_table]:mb-6 [&_table]:text-sm
      [&_th]:bg-[#e8e5dd] [&_th]:p-2 [&_th]:text-left [&_th]:font-semibold
      [&_td]:p-2 [&_td]:border-b [&_td]:border-[#e0ddd5]
      [&_hr]:my-8 [&_hr]:border-[#e0ddd5]
      [&_strong]:text-[#1a1a1a]
      [&_a]:text-emerald-700 [&_a]:underline [&_a]:underline-offset-2 hover:[&_a]:text-emerald-600
    " itemprop="text">
      <slot />
    </div>
  </article>
</Base>
